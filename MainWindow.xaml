<Window x:Class="AIDailyNews.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AIDailyNews"
        xmlns:tb="clr-namespace:Hardcodet.Wpf.TaskbarNotification;assembly=Hardcodet.NotifyIcon.Wpf"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:AIDailyNews.ViewModels"
        xmlns:models="clr-namespace:AIDailyNews.Models"
        xmlns:conv="clr-namespace:AIDailyNews.Converters"
        mc:Ignorable="d"
        Title="AI 每日快讯" Height="600" Width="900"
        WindowStartupLocation="CenterScreen"
        TextElement.FontFamily="{materialDesign:MaterialDesignFont}"
        FontFamily="{materialDesign:MaterialDesignFont}"
        StateChanged="Window_StateChanged"
        Closing="Window_Closing">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <conv:BoolToFontWeightConverter x:Key="ReadWeightConverter" />
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolVisConverter" />
        <BooleanToVisibilityConverter x:Key="BoolVisConverter" />
    </Window.Resources>

    <materialDesign:DialogHost Identifier="RootDialog">
        <DockPanel>
            <!-- 顶部工具栏 -->
            <Border DockPanel.Dock="Top"
                    BorderBrush="{DynamicResource MaterialDesignDivider}"
                    BorderThickness="0,0,0,1"
                    Padding="12,8">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Right"
                                Orientation="Horizontal">
                        <Button Command="{Binding ManageTopicsCommand}"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                Margin="4,0" ToolTip="管理关注主题">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Settings" Height="18" Width="18" />
                                <TextBlock Text=" 主题" Margin="4,0,0,0" />
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding RefreshCommand}"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                Margin="4,0" ToolTip="刷新">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Refresh" Height="18" Width="18" />
                                <TextBlock Text=" 刷新" Margin="4,0,0,0" />
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <TextBox materialDesign:TextFieldAssist.HasClearButton="True"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             materialDesign:HintAssist.Hint="搜索标题或摘要..."
                             Margin="0,0,12,0"
                             Width="280"
                             VerticalAlignment="Center" />

                    <ComboBox ItemsSource="{Binding TopicFilterItems}"
                              SelectedItem="{Binding SelectedTopic}"
                              DisplayMemberPath="Name"
                              Width="200"
                              VerticalAlignment="Center" />
                </DockPanel>
            </Border>

            <!-- 新闻列表 -->
            <ListBox ItemsSource="{Binding FilteredNews}"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     BorderThickness="0"
                     VirtualizingPanel.ScrollUnit="Pixel">
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:NewsItem}">
                        <Border Padding="12,8"
                                Margin="0,2,0,0"
                                BorderBrush="{DynamicResource MaterialDesignDivider}"
                                BorderThickness="0,0,0,1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- 标题 -->
                                <TextBlock Grid.Row="0" Grid.Column="0"
                                           Text="{Binding Title}"
                                           FontWeight="{Binding IsRead, Converter={StaticResource ReadWeightConverter}}"
                                           TextWrapping="NoWrap"
                                           TextTrimming="CharacterEllipsis"
                                           FontSize="15"
                                           ToolTip="{Binding Title}" />

                                <!-- 日期 -->
                                <TextBlock Grid.Row="0" Grid.Column="1"
                                           Text="{Binding PublishDate, StringFormat='{}{0:MM/dd HH:mm}'}"
                                           FontSize="12"
                                           Foreground="{DynamicResource MaterialDesignBodyLight}"
                                           Margin="8,0,0,0" />

                                <!-- 摘要 -->
                                <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                           Text="{Binding Summary}"
                                           TextWrapping="NoWrap"
                                           TextTrimming="CharacterEllipsis"
                                           FontSize="13"
                                           Foreground="{DynamicResource MaterialDesignBodyLight}"
                                           MaxHeight="40"
                                           Margin="0,2,0,0" />

                                <!-- 底部信息 -->
                                <StackPanel Grid.Row="2" Grid.Column="0"
                                            Orientation="Horizontal"
                                            Margin="0,4,0,0">
                                    <Border Background="{DynamicResource MaterialDesignChipBackground}"
                                            CornerRadius="4" Padding="6,0">
                                        <TextBlock Text="{Binding TopicName}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource MaterialDesignBodyLight}" />
                                    </Border>
                                    <TextBlock Text="{Binding Source}"
                                               FontSize="11"
                                               Foreground="{DynamicResource MaterialDesignBodyLight}"
                                               Margin="8,0,0,0" />
                                </StackPanel>

                                <!-- 操作按钮 -->
                                <StackPanel Grid.Row="2" Grid.Column="1"
                                            Orientation="Horizontal"
                                            Margin="0,4,0,0">
                                    <Button Command="{Binding DataContext.MarkAsReadCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            Visibility="{Binding IsRead, Converter={StaticResource InverseBoolVisConverter}}"
                                            Style="{StaticResource MaterialDesignFlatButton}"
                                            ToolTip="标记已读" FontSize="12" Padding="4,0">
                                        <materialDesign:PackIcon Kind="CheckCircleOutline" Height="16" Width="16" />
                                    </Button>
                                    <Button Command="{Binding DataContext.OpenLinkCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource MaterialDesignFlatButton}"
                                            ToolTip="在浏览器中打开" FontSize="12" Padding="4,0">
                                        <materialDesign:PackIcon Kind="OpenInNew" Height="16" Width="16" />
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- 底部状态栏 -->
            <StatusBar DockPanel.Dock="Bottom">
                <StatusBarItem>
                    <TextBlock Text="{Binding StatusText}" />
                </StatusBarItem>
                <StatusBarItem HorizontalAlignment="Right">
                    <ProgressBar IsIndeterminate="True"
                                 Visibility="{Binding IsLoading, Converter={StaticResource BoolVisConverter}}"
                                 Width="120" Height="16" />
                </StatusBarItem>
            </StatusBar>

            <!-- 系统托盘 -->
            <tb:TaskbarIcon x:Name="TrayIcon"
                            ToolTipText="AI 每日快讯"
                            Visibility="Visible"
                            MenuActivation="LeftClick">
                <tb:TaskbarIcon.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="显示窗口" Command="{Binding ShowWindowCommand}" />
                        <MenuItem Header="刷新" Command="{Binding RefreshCommand}" />
                        <Separator />
                        <MenuItem Header="退出" Command="{Binding ExitCommand}" />
                    </ContextMenu>
                </tb:TaskbarIcon.ContextMenu>
            </tb:TaskbarIcon>
        </DockPanel>
    </materialDesign:DialogHost>
</Window>
